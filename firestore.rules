// =============================================================
// firestore.rules — Firestore Security Rules (HARDENED v3)
// =============================================================
// Per-collection whitelist with default deny for unlisted collections.
// All 9 app collections are explicitly listed.
// =============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{docId} {
      allow read, write: if request.auth != null;
    }

    match /subjects/{docId} {
      allow read, write: if request.auth != null;
    }

    match /questionnaires/{docId} {
      allow read, write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /enrollments/{docId} {
      allow read, write: if request.auth != null;
    }

    match /responses/{docId} {
      allow read, write: if request.auth != null;
    }

    match /attendance/{docId} {
      allow read, write: if request.auth != null;
    }

    // Push notification collections
    match /fcm_tokens/{docId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }

    // DEFAULT DENY: block all unlisted collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
