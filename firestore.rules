// ============================================================
// firestore.rules — Firestore Security Rules
// ============================================================
// All logged-in users can read/write. Unauthorized access blocked.
// User documents protected: each user can only access their own.
// Role-based filtering handled client-side by firebase-sync.js.
// Deploy in Firebase Console > Firestore > Rules tab.
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: each user can only read/write their OWN document
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // All other collections: any logged-in user can read/write
    // Blocks all unauthenticated/unauthorized access
    match /{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
