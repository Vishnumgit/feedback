// =============================================================
// firestore.rules — Firestore Security Rules (HARDENED v2)
// =============================================================
// SECURITY: Per-collection rules with default deny.
// Any authenticated user (including anonymous fallback) can
// read/write whitelisted collections. All unlisted collections
// are blocked. This is more secure than the original catch-all
// while remaining compatible with the app's auth patterns.
// =============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any authenticated user can read/write
    // (admin needs to manage all user docs)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Subjects: any authenticated user
    match /subjects/{docId} {
      allow read, write: if request.auth != null;
    }

    // Questionnaires: any authenticated user
    match /questionnaires/{docId} {
      allow read, write: if request.auth != null;
    }

    // Settings: any authenticated user
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    // Enrollments: any authenticated user
    match /enrollments/{docId} {
      allow read, write: if request.auth != null;
    }

    // Responses: any authenticated user
    match /responses/{docId} {
      allow read, write: if request.auth != null;
    }

    // Attendance: any authenticated user
    match /attendance/{docId} {
      allow read, write: if request.auth != null;
    }

    // DEFAULT DENY: block all unlisted collections
    // This prevents access to any collection not explicitly listed above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
