// =============================================================
// firestore.rules — Firestore Security Rules (HARDENED v7)
// =============================================================
// v7: Tightened users collection — requires authentication to read.
//     Firebase Auth handles login, so public read is no longer needed.
//     Settings stays public read (login pages need college domain).
// =============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: true only for non-anonymous authenticated users
    function isRealUser() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Users: authenticated read (login uses Firebase Auth, not Firestore lookup)
    // Any signed-in user can read profiles; only real users can write
    match /users/{docId} {
      allow read: if request.auth != null;
      allow write: if isRealUser();
    }

    match /subjects/{docId} {
      allow read, write: if isRealUser();
    }

    match /questionnaires/{docId} {
      allow read, write: if isRealUser();
    }

    // Settings: public read (login pages need college domain before auth)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isRealUser();
    }

    match /enrollments/{docId} {
      allow read, write: if isRealUser();
    }

    match /responses/{docId} {
      allow read, write: if isRealUser();
    }

    match /attendance/{docId} {
      allow read, write: if isRealUser();
    }

    match /notifications/{docId} {
      allow read, write: if isRealUser();
    }

    match /timetables/{docId} {
      allow read, write: if isRealUser();
    }

    // Default deny for any unlisted collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
