// =============================================================
// firestore.rules — Firestore Security Rules (HARDENED v6)
// =============================================================
// v5: Public read on settings for login pages
// v6: Public read on users for cross-device login lookups
//     (passwordHash is SHA-256 — not plaintext)
// =============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: true only for non-anonymous authenticated users
    function isRealUser() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Users: public read for cross-device login lookups
    // Write still requires real authenticated user
    match /users/{docId} {
      allow read: if true;
      allow write: if isRealUser();
    }

    match /subjects/{docId} {
      allow read, write: if isRealUser();
    }

    match /questionnaires/{docId} {
      allow read, write: if isRealUser();
    }

    // Settings: public read (non-sensitive: college name, domain, threshold)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isRealUser();
    }

    match /enrollments/{docId} {
      allow read, write: if isRealUser();
    }

    match /responses/{docId} {
      allow read, write: if isRealUser();
    }

    match /attendance/{docId} {
      allow read, write: if isRealUser();
    }

    match /notifications/{docId} {
      allow read, write: if isRealUser();
    }

    match /timetables/{docId} {
      allow read, write: if isRealUser();
    }

    // Default deny for any unlisted collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
