// =============================================================
// firestore.rules — Firestore Security Rules (HARDENED v4)
// =============================================================
// SECURITY FIX: Rejects anonymous auth users. Only real logins
// (email/password or Google Sign-In) get read/write access.
// Anonymous auth provider is explicitly blocked.
// =============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: true only for non-anonymous authenticated users
    function isRealUser() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    match /users/{docId} {
      allow read, write: if isRealUser();
    }

    match /subjects/{docId} {
      allow read, write: if isRealUser();
    }

    match /questionnaires/{docId} {
      allow read, write: if isRealUser();
    }

    match /settings/{docId} {
      allow read, write: if isRealUser();
    }

    match /enrollments/{docId} {
      allow read, write: if isRealUser();
    }

    match /responses/{docId} {
      allow read, write: if isRealUser();
    }

    match /attendance/{docId} {
      allow read, write: if isRealUser();
    }

    match /notifications/{docId} {
      allow read, write: if isRealUser();
    }

    match /timetables/{docId} {
      allow read, write: if isRealUser();
    }

    // Default deny for any unlisted collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
